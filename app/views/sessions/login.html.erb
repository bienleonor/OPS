<div class="flex items-center justify-center min-h-[70vh]">
  <div class="bg-white shadow-lg rounded-2xl p-8 w-full max-w-md">

    <h1 class="text-2xl font-bold mb-6 text-center">Login</h1>
    <%= form_with url: login_path, local: true, class: "space-y-4" do |form| %>
      <div>
        <%= form.label :email, class: "block text-sm font-medium text-gray-700" %>
        <%= form.email_field :email,
              class: "mt-1 w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>
      <div>
        <%= form.label :password, class: "block text-sm font-medium text-gray-700" %>
        <%= form.password_field :password,
              class: "mt-1 w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>
      <div>
        <%= form.submit "Login",
              class: "w-full bg-blue-600 hover:bg-blue-700 text-white py-2 px-4 rounded-md font-medium transition duration-200" %>
      </div>
    <% end %>
    <% if flash[:alert] %>
      <div class="mt-4 bg-red-100 border border-red-400 text-red-700 px-4 py-2 rounded">
        <%= flash[:alert] %>
      </div>
    <% end %>
  </div>
</div>
