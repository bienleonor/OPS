<div class="max-w-md mx-auto mt-10 p-6 bg-white rounded-lg shadow">
  <h2 class="text-2xl font-bold mb-6">Send Money</h2>

  <% if flash[:alert] %>
    <div class="mb-4 p-3 bg-red-100 text-red-700 rounded">
      <%= flash[:alert] %>
    </div>
  <% end %>

  <% if flash[:notice] %>
    <div class="mb-4 p-3 bg-green-100 text-green-700 rounded">
      <%= flash[:notice] %>
    </div>
  <% end %>

  <%= form_with url: transfers_path, method: :post do |f| %>
    <%# Current balance %>
    <div class="mb-4 p-3 bg-gray-50 rounded">
      <span class="text-sm text-gray-500">Your balance:</span>
      <span class="font-bold text-lg ml-2">₱ <%= current_user.wallet.balance %></span>
    </div>

    <%# Receiver email %>
    <div class="mb-4">
      <%= f.label :receiver_email, "Receiver Email", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.email_field :receiver_email,
            placeholder: "recipient@example.com",
            class: "w-full px-3 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-blue-500",
            required: true %>
    </div>

    <%# Amount %>
    <div class="mb-6">
      <%= f.label :amount, "Amount", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <div class="relative">
        <span class="absolute left-3 top-2 text-gray-500">₱</span>
        <%= f.number_field :amount,
              placeholder: "0.00",
              min: 0.01,
              step: 0.01,
              class: "w-full pl-7 pr-3 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-blue-500",
              required: true %>
      </div>
    </div>

    <%# Submit %>
    <%= f.submit "Send Money",
          class: "w-full py-2 px-4 bg-blue-500 hover:bg-blue-600 text-white font-semibold rounded transition duration-200 cursor-pointer" %>
  <% end %>

  <div class="mt-4 text-center">
    <%= link_to "← Back to Home", home_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
  </div>
</div>